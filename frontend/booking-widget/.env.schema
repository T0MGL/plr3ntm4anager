# Public backend API base URL. In production this points to the booking API
# behind rent.parkloftsparaguay.com. Leave off the trailing slash.
VITE_API_URL=http://localhost:3000/api

# Google Maps JavaScript API key, referrer-restricted to the rent domain and
# localhost. Required for the "Donde estaras" section on the unit detail page.
# Without this key the map falls back to the "Abrir en Google Maps" button.
VITE_GOOGLE_MAPS_API_KEY=
